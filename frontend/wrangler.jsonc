{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "luckyreads",
  "compatibility_date": "2026-04-20",
  "workers_dev": false,
  "preview_urls": false,
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}